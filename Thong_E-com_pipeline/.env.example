# Copy file này thành .env và điền giá trị thật
# cp .env.example .env

# ── GCP ─────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=ecom-pipeline-raw
BQ_DATASET=ecom_warehouse

# Đặt file service account key tại: ./secrets/gcp-sa-key.json
# Tạo SA key: GCP Console → IAM → Service Accounts → Keys → Create JSON key
# Roles cần thiết: Storage Object Admin, BigQuery Data Editor, BigQuery Job User

# ── PostgreSQL (local) ───────────────────────────────────────────────────────
DB_HOST=postgres
DB_NAME=ecom_db
DB_USER=airflow
DB_PASSWORD=airflow
